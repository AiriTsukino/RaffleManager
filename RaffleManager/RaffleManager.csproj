<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
    <AssemblyName>RaffleManager</AssemblyName>
    <RootNamespace>RaffleManager</RootNamespace>
    <Version>0.2.10.0</Version>
    <Description>Ticket-based venue raffle manager for FFXIV venues.</Description>
    <IsPackable>false</IsPackable>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="Resources\tick.wav" CopyToOutputDirectory="Always" CopyToPublishDirectory="Always" />
    <EmbeddedResource Include="Resources\tick.wav" />
    <Content Include="Resources\tick.mp3" CopyToOutputDirectory="Always" CopyToPublishDirectory="Always" />
  </ItemGroup>
</Project>
